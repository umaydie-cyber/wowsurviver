{
  "compilerOptions": {
    "target": "ES2022", "useDefineForClassFields": true, "module": "ESNext",
    "lib": ["ES2022", "DOM"], "moduleResolution": "Bundler", "strict": true,
    "noUnusedLocals": true, "noUnusedParameters": true, "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "vite.config.ts"]
}
